require: slotfilling/slotFilling.sc
  module = sys.zb-common

# ====== ПАТТЕРНЫ ИНТЕНТОВ ======

patterns:
    $hello = (привет*|здравствуй*|добр* (утр*|ден*|вечер*)|хай|hello|hi|приветствую|здравствуйте|доброго времени)
    $weather = (погод*|прогноз*|какая погода|на улице|дожд*|солнечно|температур* (на улице|воздуха)|тепло|холодно|будет ли дождь|какая на улице)
    $currency = (курс*|валют*|доллар*|евро*|сколько стоит (доллар|евро)|обмен* (валют|курс)|по чем* (доллар|евро)|рубл*|конвертац*)

# ====== СОСТОЯНИЯ ======

theme: /

    state: Start
        q!: $regex</start>
        a: Привет! Я бот-помощник. Могу рассказать о погоде и курсах валют.

    state: hello || modal = false
        intent!: $hello
        q!: * $hello *
        a: Здравствуйте! Я ваш помощник. Спросите меня про погоду или курс валют.

    state: weather || modal = false
        intent!: $weather
        q!: * $weather *
        a: Сегодня переменная облачность, температура около +15°C, без осадков.

    state: currency || modal = false
        intent!: $currency
        q!: * $currency *
        a: Текущий курс: 1 USD ≈ 90 RUB, 1 EUR ≈ 98 RUB.

    state: NoMatch || noContext = true
        event!: noMatch
        a: Извините, я вас не понял. Я умею рассказывать о погоде и курсах валют.